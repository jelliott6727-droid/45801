<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Lecture 1 Board</title>

<!-- ✅ Lato font -->
<link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700&display=swap" rel="stylesheet">

<style>
body {
  margin:0;
  font-family:'Lato', sans-serif;
  background:#eef2f7;
}

body.lms { font-size:14px; }
body.presentation { font-size:18px; }

header {
  background: linear-gradient(135deg, #4a6cf7, #6f8cff);
  color:white;
  text-align:center;
  font-weight:700;
}

body.lms header {
  padding:12px;
  font-size:20px;
}

body.presentation header {
  padding:18px;
  font-size:28px;
}

#toolbar {
  display:none;
  gap:10px;
  background:white;
}

body.lms #toolbar { padding:10px; }
body.presentation #toolbar { padding:16px; }

input {
  border-radius:8px;
  border:1px solid #ccc;
  width:100%;
}

body.lms input {
  padding:8px;
  font-size:14px;
}

body.presentation input {
  padding:12px;
  font-size:18px;
}

button {
  background:#4a6cf7;
  color:white;
  border:none;
  border-radius:8px;
  cursor:pointer;
}

body.lms button {
  padding:8px 12px;
  font-size:14px;
}

body.presentation button {
  padding:12px 16px;
  font-size:18px;
}

#board {
  position:relative;
  height:calc(100vh - 80px);
  background-image: radial-gradient(#d1d5db 1px, transparent 1px);
}

body.lms #board { background-size:20px 20px; }
body.presentation #board { background-size:30px 30px; }

.note {
  position:absolute;
  border-radius:12px;
  box-shadow:0 6px 16px rgba(0,0,0,0.2);
}

body.lms .note {
  width:220px;
  padding:10px;
}

body.presentation .note {
  width:300px;
  padding:16px;
}

.delete {
  float:right;
  color:#cc0000;
  cursor:pointer;
}

.vote {
  margin-top:8px;
  text-align:center;
  background:#f1f5ff;
  border-radius:8px;
  cursor:pointer;
}

body.lms .vote { padding:6px; font-size:13px; }
body.presentation .vote { padding:10px; font-size:16px; }

#addBtn {
  position:fixed;
  bottom:20px;
  right:20px;
  border-radius:50%;
  border:none;
  background:#4a6cf7;
  color:white;
  cursor:pointer;
}

body.lms #addBtn {
  width:55px;
  height:55px;
  font-size:24px;
}

body.presentation #addBtn {
  width:75px;
  height:75px;
  font-size:32px;
}

#clearBtn {
  position:fixed;
  bottom:20px;
  left:20px;
  background:#ef4444;
  color:white;
  border:none;
  border-radius:8px;
  cursor:pointer;
}

body.lms #clearBtn {
  font-size:12px;
  padding:8px 10px;
}

body.presentation #clearBtn {
  font-size:16px;
  padding:12px 14px;
}

#modeBtn {
  position:fixed;
  top:10px;
  right:20px;
  background:#111827;
  color:white;
  border:none;
  border-radius:8px;
  cursor:pointer;
  padding:6px 10px;
}
</style>
</head>

<body class="lms">

<header>Lecture 1 Discussion Board</header>

<button id="modeBtn" onclick="toggleMode()">Switch Mode</button>

<div id="toolbar">
  <input id="name" placeholder="Your name">
  <input id="text" placeholder="Enter your response">
  <button onclick="addNote()">Post</button>
</div>

<div id="board"></div>

<button id="addBtn" onclick="toggleInput()">+</button>
<button id="clearBtn" onclick="clearBoard()">Delete All Notes</button>

<!-- ✅ Firebase -->
<script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
